# endpoints
BINANCE_SPOT_BASE=https://api.binance.com
BINANCE_UM_BASE=https://fapi.binance.com
BINANCE_CM_BASE=https://dapi.binance.com

# storage
REDIS_URL=redis://127.0.0.1/
CACHE_TTL_SEC=3600
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_DB=db_trading

# filters
ONLY_TRADING=true
ALLOWED_QUOTES=USDT,USDC

# which markets
SAVE_SPOT=true
SAVE_UM=true
SAVE_CM=true

# redis keys
REDIS_KEY_SPOT=instruments:binance:spot
REDIS_KEY_UM=instruments:binance:um
REDIS_KEY_CM=instruments:binance:cm
